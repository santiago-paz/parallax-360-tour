# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# user-generated authoring data (auto-created by /api/polygons on first write)
/data/scenes.json
# user-uploaded product images (auto-created by /api/upload)
/public/products/*
!/public/products/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/scripts/.venv
# scripts — track *.py + *.sh source files, not generated artifacts
/scripts/**/*
!/scripts/*.py
!/scripts/*.sh

# Python virtual environments
venv/
venv/*
.venv/
.venv/*
env/
ENV/
*.pyc
__pycache__/

# Vendored packages (external deps, weights)
/vendor/

# build_scene.py state
/app/scenes.ts.bak
/scripts/__pycache__/
.worktrees/

# Claude Code session/config
.claude/

# Dev-only screenshot scratch dir
.spike-screens/
